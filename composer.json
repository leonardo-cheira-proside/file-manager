{
    "name": "proside/file-manager",
    "description": "File Manager reutilizável para Laravel, construído em Livewire v4 (substitui o File Manager Next.js da Proside).",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": ["laravel", "livewire", "file-manager", "media", "proside"],
    "authors": [
        { "name": "Proside" }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Proside\\FileManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Proside\\FileManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Proside\\FileManager\\FileManagerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
